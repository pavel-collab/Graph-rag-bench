# LLM settings (OpenAI-compatible API)
OPENAI_API_KEY=your-api-key-here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# PostgreSQL (LightRAG KV storage)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lightrag

# Neo4j (LightRAG graph storage)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Qdrant (LightRAG vector storage)
QDRANT_URL=http://localhost:6333

# Redis (LightRAG alternative KV storage / caching)
REDIS_URL=redis://localhost:6379

# Storage paths
LIGHTRAG_WORKING_DIR=./storage/lightrag
HIPPORAG_WORKING_DIR=./storage/hipporag
